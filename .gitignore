# Build artifacts
build/
*.o
*.obj
*.a
*.so
*.dylib
*.pc
*.lib
*.pdb
*.ilk
**__pycache__*

# Executables
src/dosiz
src/dosiz.exe
*.exe

# Re-include committed DOS test fixtures (pre-built binaries under
# tests/ are part of the repo so CI doesn't need a cross-compiler).
!tests/*.exe
!tests/*.EXE

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake

# vcpkg (if used for dosbox deps)
vcpkg_installed/

# Downloaded / built DOS disk images
fd/
*.img

# Packaging artifacts
dist/
*.msix
*.deb
*.rpm
*.pfx

# Editor / OS
*~
*.swp
.vscode/
.idea/
.DS_Store
Thumbs.db

# Test artifacts dropped in the repo root when WRITE.COM is run bare
# (no .cfg redirecting the output file).  CI always runs inside a
# mktemp dir, so this only matters for developers running the
# fixture straight from the command line.
WROTE.TXT
djfile.tmp

# Post-build symlink created by src/CMakeLists.txt so dosbox finds
# its Resources/ (Unicode mapping files, glshaders, etc.) without
# a full install.
/Resources
